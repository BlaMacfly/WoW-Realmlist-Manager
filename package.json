{
  "name": "wow-realmlist-manager",
  "version": "3.0.0",
  "description": "A modern tool to manage your World of Warcraft realmlist.wtf and switch between private servers in one click.",
  "main": "main.js",
  "author": "BlaMacfly",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --config.win.signAndEditExecutable=false",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:linux": "electron-builder --linux deb"
  },
  "build": {
    "appId": "com.wowrealmlistmanager.app",
    "productName": "WoW Realmlist Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "assets/**/*",
      "icon.png",
      "icon.ico"
    ],
    "win": {
      "target": ["portable"],
      "icon": "icon.ico"
    },
    "linux": {
      "target": ["deb"],
      "icon": "icon.png",
      "category": "Game",
      "maintainer": "BlaMacfly",
      "description": "A tool to manage WoW realm lists"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  }
}
